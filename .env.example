# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
PROJECT_NAME=Appointment360 API
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True
DESCRIPTION=Async FastAPI backend for Contact360 - Contact Management System

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_V1_STR=/api
API_V1_PREFIX=/api/v1
API_V2_PREFIX=/api/v2
API_V3_PREFIX=/api/v3
API_V4_PREFIX=/api/v4
DOCS_URL=/docs
REDOC_URL=/redoc

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASS=r8Rwu87mt$8N#nq
POSTGRES_HOST=ayan.calum4mgqi7l.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
DATABASE_ECHO=False

# Database Connection Pool Settings
DATABASE_POOL_SIZE=25
DATABASE_MAX_OVERFLOW=50
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=True
DATABASE_POOL_RESET_ON_RETURN=commit

# Database Replica (Optional - for read operations)
DATABASE_REPLICA_URL=
USE_REPLICA=False

# Database Query Optimization
ENABLE_QUERY_COMPRESSION=True
QUERY_CACHE_TTL=300
ENABLE_QUERY_CACHING=False
ENABLE_QUERY_MONITORING=True
SLOW_QUERY_THRESHOLD=1.0
USE_APPROXIMATE_COUNTS=False
APOLLO_COUNT_MAX_CONCURRENT=50

# Connection Pool Monitoring
ENABLE_POOL_MONITORING=True
POOL_MONITORING_INTERVAL=60

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
CONTACTS_WRITE_KEY=change-this-write-key
COMPANIES_WRITE_KEY=change-this-write-key

# =============================================================================
# CORS & NETWORK CONFIGURATION
# =============================================================================
# Allowed origins for browser-based clients (comma-separated or JSON array)
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:8000"]
# Alternative format (comma-separated): ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000

# Trusted hosts (comma-separated)
TRUSTED_HOSTS=54.87.173.234,3.95.58.90,54.87.173.234:8000,localhost,127.0.0.1,testserver

# Proxy and forwarding
ROOT_PATH=
USE_PROXY_HEADERS=True
FORWARDED_ALLOW_IPS=*

# =============================================================================
# REDIS & CELERY CONFIGURATION
# =============================================================================
REDIS_HOST=54.87.173.234
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://54.87.173.234:6379/0

# Celery Configuration (using Redis as broker and result backend)
CELERY_BROKER_URL=redis://54.87.173.234:6379/0
CELERY_RESULT_BACKEND=redis://54.87.173.234:6379/0

# Redis Caching (Optional)
ENABLE_REDIS_CACHE=False

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_DIR=./uploads
MEDIA_URL=/media
BASE_URL=http://54.87.173.234:8000

# File Upload Limits
MAX_UPLOAD_CHUNK_SIZE=1048576
MAX_UPLOAD_SIZE=

# =============================================================================
# AWS S3 CONFIGURATION
# =============================================================================
# AWS Credentials (Optional - required for S3 operations)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 Bucket Configuration
S3_BUCKET_NAME=
S3_V3_BUCKET_NAME=tkdrawcsvdata
S3_AVATARS_PREFIX=avatars/
S3_EXPORTS_PREFIX=exports/

# S3 URL Configuration
S3_USE_PRESIGNED_URLS=True
S3_PRESIGNED_URL_EXPIRATION=3600

# =============================================================================
# BULKMAILVERIFIER CONFIGURATION
# =============================================================================
BULKMAILVERIFIER_EMAIL=mr.ayansaha@gmail.com
BULKMAILVERIFIER_PASSWORD=Bangalore@2020
BULKMAILVERIFIER_BASE_URL=https://app.bulkmailverifier.com
BULKMAILVERIFIER_MAX_RETRIES=10

# =============================================================================
# GEMINI AI CONFIGURATION
# =============================================================================
GEMINI_API_KEY=AIzaSyD6V9YMYJmkh8ot-RV7iZYVV_XVSSM0SuM

# Model Selection
GEMINI_MODEL=gemini-1.5-flash

# Generation Parameters
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40

# System Instructions (Multi-line - keep as single line in .env or use quotes)
GEMINI_SYSTEM_INSTRUCTION="You are NexusAI, a smart CRM assistant for Contact360. You help users with:\\n- Finding contacts matching specific criteria (titles, locations, industries, etc.)\\n- Searching for leads in specific industries or locations\\n- Getting insights about companies\\n- Answering questions about CRM data\\n- Natural language queries about contacts and companies\\n\\nBe helpful, concise, and professional. When users ask about finding contacts or leads, provide guidance on what criteria they can use. If they ask specific questions about data, acknowledge that you can help them search once they provide the criteria."

# Retry Configuration
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=1.0

# Rate Limiting
AI_RATE_LIMIT_REQUESTS=20
AI_RATE_LIMIT_WINDOW=60

# =============================================================================
# PAGINATION CONFIGURATION
# =============================================================================
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

# =============================================================================
# RESPONSE COMPRESSION
# =============================================================================
ENABLE_RESPONSE_COMPRESSION=True
COMPRESSION_MIN_SIZE=1000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# BIG DATA & PERFORMANCE CONFIGURATION
# =============================================================================

# Streaming Configuration
STREAMING_CHUNK_SIZE=1048576
ENABLE_STREAMING_QUERIES=True
MAX_STREAMING_RESULTS=
STREAMING_BATCH_SIZE=1000

# Parallel Processing
PARALLEL_PROCESSING_WORKERS=4
PARALLEL_PROCESSING_MAX_WORKERS=8
ENABLE_PARALLEL_PROCESSING=True

# Background Tasks
MAX_CONCURRENT_BACKGROUND_TASKS=10
BACKGROUND_TASK_TIMEOUT=30.0

# In-Memory Caching
CACHE_MAX_SIZE=1000
ENABLE_CACHE_WARMING=False
CACHE_WARMING_QUERIES=

# HTTP Cache Configuration
ENABLE_HTTP_CACHE=True
HTTP_CACHE_MAX_AGE=300
HTTP_CACHE_PUBLIC=True
HTTP_CACHE_MUST_REVALIDATE=False
HTTP_CACHE_STATIC_MAX_AGE=31536000
HTTP_CACHE_API_MAX_AGE=300
